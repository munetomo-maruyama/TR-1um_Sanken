* cell TOP  FRAME
* pin  1    P1
* pin  2    P2
*
* pin  3    P3
* pin  4    P4
* pin  5    P5
* pin  6    P6
*
* pin  7    P7
* pin  8    VSS
* pin  9    P9
* pin 10    P10
*
* pin 11    P11
* pin 12    P12
* pin 13    P13
* pin 14    P14
*
* pin 15    P15
* pin 16    VDD

.SUBCKT tr_1um_munetomo_maruyama P1 P2 P3 P4 P5 P6 P7 VSS P9 P10 P11 P12 P13 P14 P15 VDD
* cell instance $1 r0 *1 0,0
X$1 P1 P2 P3 P4 P5 P6 P7 VSS P9 P10 P11 P12 P13 P14 P15 VDD OSS_FRAME
* cell instance mmINVERTER
X$2 VDD P1 P2 VSS mmINVERTER
.ENDS tr_1um_munetomo_maruyama

* cell mmINVERTER
.subckt mmINVERTER VDD A Q VSS
*.PININFO VSS:B VDD:B A:I Q:O
M1 Q A VDD VDD PMOS w=12u l=1u nrd=0 nrs=0 m=1
M2 Q A VSS VSS NMOS w=4u l=1u nrd=0 nrs=0 m=1
.ends

* cell OSS_FRAME
* pin P1
* pin P2
*
* pin P3
* pin P4
* pin P5
* pin P6
*
* pin P7
* pin VSS
* pin P9
* pin P10
*
* pin P11
* pin P12
* pin P13
* pin P14
*
* pin P15
* pin VDD

.SUBCKT OSS_FRAME P1 P2 P3 P4 P5 P6 P7 VSS P9 P10 P11 P12 P13 P14 P15 VDD
*
* cell instance $18 r180 *1 -200,1040
X$18 P1 VDD VSS OSS_ESD_5V_ANA
* cell instance $20 m0 *1 -600,1040
X$20 P2 VDD VSS OSS_ESD_5V_ANA
*
* cell instance $10 r270 *1 -1040,600
X$10 P3 VDD VSS OSS_ESD_5V_ANA
* cell instance $3 m45 *1 -1040,200
X$3 P4 VDD VSS OSS_ESD_5V_ANA
* cell instance $6 r270 *1 -1040,-200
X$6 P5 VDD VSS OSS_ESD_5V_ANA
* cell instance $8 m45 *1 -1040,-600
X$8 P6 VDD VSS OSS_ESD_5V_ANA
*
* cell instance $9 r0 *1 -600,-1040
X$9 P7 VDD VSS OSS_ESD_5V_ANA
* cell instance $15 m90 *1 -200,-1040
X$15 VDD VSS OSS_ESD_5V_VSS
* cell instance $14 r0 *1 200,-1040
X$14 P9 VDD VSS OSS_ESD_5V_ANA
* cell instance $12 m90 *1 600,-1040
X$12 P10 VDD VSS OSS_ESD_5V_ANA
*
* cell instance $2 r90 *1 1040,-600
X$2 P11 VDD VSS OSS_ESD_5V_ANA
* cell instance $16 m135 *1 1040,-200
X$16 P12 VDD VSS OSS_ESD_5V_ANA
* cell instance $1 r90 *1 1040,200
X$1 P13 VDD VSS OSS_ESD_5V_ANA
* cell instance $5 m135 *1 1040,600
X$5 P14 VDD VSS OSS_ESD_5V_ANA
*
* cell instance $4 r180 *1 600,1040
X$4 P15 VDD VSS OSS_ESD_5V_ANA
* cell instance $19 m0 *1 200,1040
X$19 VDD VSS OSS_ESD_5V_VDD
*
.ENDS OSS_FRAME

* cell OSS_ESD_5V_VSS
* pin VDD
* pin PAD,VSS
.SUBCKT OSS_ESD_5V_VSS VDD PAD|VSS
* cell instance $1 r90 *1 -130,0
X$1 PAD|VSS VDD OSS_PCH_ESD
* cell instance $4 r90 *1 130,0
X$4 PAD|VSS PAD|VSS OSS_NCH_ESD
.ENDS OSS_ESD_5V_VSS

* cell OSS_ESD_5V_VDD
* pin PAD,VDD
* pin VSS
.SUBCKT OSS_ESD_5V_VDD PAD|VDD VSS
* cell instance $1 r90 *1 -130,0
X$1 PAD|VDD PAD|VDD OSS_PCH_ESD
* cell instance $4 r90 *1 130,0
X$4 PAD|VDD VSS OSS_NCH_ESD
.ENDS OSS_ESD_5V_VDD

* cell OSS_ESD_5V_ANA
* pin PAD
* pin VDD
* pin VSS
.SUBCKT OSS_ESD_5V_ANA PAD VDD VSS
* cell instance $2 r90 *1 -130,0
X$2 PAD VDD OSS_PCH_ESD
* cell instance $3 r90 *1 130,0
X$3 PAD VSS OSS_NCH_ESD
.ENDS OSS_ESD_5V_ANA

* cell OSS_PCH_ESD
* pin PAD
* pin VDD
.SUBCKT OSS_PCH_ESD PAD VDD
* device instance $1 r0 *1 -65.5,0 PMOS
M$1 VDD VDD PAD VDD PMOS L=2U W=50U AS=698.04P AD=225P PS=126.36U PD=59U
* device instance $2 r0 *1 -54.5,0 PMOS
M$2 PAD VDD VDD VDD PMOS L=2U W=50U AS=225P AD=425P PS=59U PD=67U
* device instance $3 r0 *1 -35.5,0 PMOS
M$3 VDD VDD PAD VDD PMOS L=2U W=50U AS=425P AD=225P PS=67U PD=59U
* device instance $4 r0 *1 -24.5,0 PMOS
M$4 PAD VDD VDD VDD PMOS L=2U W=50U AS=225P AD=425P PS=59U PD=67U
* device instance $5 r0 *1 -5.5,0 PMOS
M$5 VDD VDD PAD VDD PMOS L=2U W=50U AS=425P AD=225P PS=67U PD=59U
* device instance $6 r0 *1 5.5,0 PMOS
M$6 PAD VDD VDD VDD PMOS L=2U W=50U AS=225P AD=425P PS=59U PD=67U
* device instance $7 r0 *1 24.5,0 PMOS
M$7 VDD VDD PAD VDD PMOS L=2U W=50U AS=425P AD=225P PS=67U PD=59U
* device instance $8 r0 *1 35.5,0 PMOS
M$8 PAD VDD VDD VDD PMOS L=2U W=50U AS=225P AD=425P PS=59U PD=67U
* device instance $9 r0 *1 54.5,0 PMOS
M$9 VDD VDD PAD VDD PMOS L=2U W=50U AS=425P AD=225P PS=67U PD=59U
* device instance $10 r0 *1 65.5,0 PMOS
M$10 PAD VDD VDD VDD PMOS L=2U W=50U AS=225P AD=698.04P PS=59U PD=126.36U
.ENDS OSS_PCH_ESD

* cell OSS_NCH_ESD
* pin PAD
* pin VSS
.SUBCKT OSS_NCH_ESD PAD VSS
* device instance $1 r0 *1 -65.5,0 NMOSE
M$1 VSS VSS PAD VSS NMOSE L=2U W=50U AS=698.04P AD=225P PS=126.36U PD=59U
* device instance $2 r0 *1 -54.5,0 NMOSE
M$2 PAD VSS VSS VSS NMOSE L=2U W=50U AS=225P AD=425P PS=59U PD=67U
* device instance $3 r0 *1 -35.5,0 NMOSE
M$3 VSS VSS PAD VSS NMOSE L=2U W=50U AS=425P AD=225P PS=67U PD=59U
